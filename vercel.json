{
  "builds": [
    {
      "src": "styleai/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "styleai/dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "styleai/dist/assets/$1"
    },
    {
      "src": "/((?!api/).*)",
      "dest": "styleai/dist/index.html"
    }
  ]
}
